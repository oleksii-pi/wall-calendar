rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function calendarKeyExists(calendarKey) {
      return exists(/databases/$(database)/documents/calendarKeys/$(calendarKey));
    }

    function validCalendarPayload() {
      return request.resource.data.keys().hasOnly([
          'schemaVersion',
          'events',
          'members',
          'memberColors',
          'deletedEventIds',
          'updatedAt'
        ])
        && request.resource.data.schemaVersion == 1
        && request.resource.data.events is list
        && request.resource.data.members is list
        && request.resource.data.memberColors is map
        && request.resource.data.deletedEventIds is map
        && request.resource.data.updatedAt is timestamp;
    }

    match /calendarKeys/{calendarKey} {
      allow read, write: if false;
    }

    match /calendars/{calendarKey} {
      allow list: if false;
      allow get: if calendarKeyExists(calendarKey);
      allow create, update: if calendarKeyExists(calendarKey)
        && validCalendarPayload();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
